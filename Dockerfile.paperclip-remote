FROM node:lts-trixie-slim AS base
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates curl git \
  && rm -rf /var/lib/apt/lists/*
RUN corepack enable

FROM base AS source
WORKDIR /src
ARG PAPERCLIP_REPO=https://github.com/paperclipai/paperclip.git
ARG PAPERCLIP_REF=master
RUN git clone --depth 1 --branch "$PAPERCLIP_REF" "$PAPERCLIP_REPO" paperclip
WORKDIR /src/paperclip

FROM base AS deps
WORKDIR /app
COPY --from=source /src/paperclip/package.json /src/paperclip/pnpm-workspace.yaml /src/paperclip/pnpm-lock.yaml /src/paperclip/.npmrc ./
COPY --from=source /src/paperclip/cli/package.json cli/
COPY --from=source /src/paperclip/server/package.json server/
COPY --from=source /src/paperclip/ui/package.json ui/
COPY --from=source /src/paperclip/packages/shared/package.json packages/shared/
COPY --from=source /src/paperclip/packages/db/package.json packages/db/
COPY --from=source /src/paperclip/packages/adapter-utils/package.json packages/adapter-utils/
COPY --from=source /src/paperclip/packages/adapters/claude-local/package.json packages/adapters/claude-local/
COPY --from=source /src/paperclip/packages/adapters/codex-local/package.json packages/adapters/codex-local/
COPY --from=source /src/paperclip/packages/adapters/cursor-local/package.json packages/adapters/cursor-local/
COPY --from=source /src/paperclip/packages/adapters/gemini-local/package.json packages/adapters/gemini-local/
COPY --from=source /src/paperclip/packages/adapters/openclaw-gateway/package.json packages/adapters/openclaw-gateway/
COPY --from=source /src/paperclip/packages/adapters/opencode-local/package.json packages/adapters/opencode-local/
COPY --from=source /src/paperclip/packages/adapters/pi-local/package.json packages/adapters/pi-local/
COPY --from=source /src/paperclip/packages/plugins/sdk/package.json packages/plugins/sdk/
COPY --from=source /src/paperclip/patches/ patches/
RUN pnpm install --frozen-lockfile

FROM base AS build
WORKDIR /app
COPY --from=deps /app /app
COPY --from=source /src/paperclip/. .
RUN node - <<'JS'
const fs = require('fs');
const path = '/app/server/src/routes/agents.ts';
const text = fs.readFileSync(path, 'utf8');
const oldBlock = `  router.post("/companies/:companyId/agents", validate(createAgentSchema), async (req, res) => {\n    const companyId = req.params.companyId as string;\n    assertCompanyAccess(req, companyId);\n\n    if (req.actor.type === "agent") {\n      assertBoard(req);\n    }\n`;
const newBlock = `  router.post("/companies/:companyId/agents", validate(createAgentSchema), async (req, res) => {\n    const companyId = req.params.companyId as string;\n    await assertCanCreateAgentsForCompany(req, companyId);\n`;
if (!text.includes(oldBlock)) {
  console.error('target block not found in agents.ts');
  process.exit(1);
}
fs.writeFileSync(path, text.replace(oldBlock, newBlock));
console.log('patched /app/server/src/routes/agents.ts to honor assertCanCreateAgentsForCompany');
JS
RUN pnpm --filter @paperclipai/ui build
RUN pnpm --filter @paperclipai/plugin-sdk build
RUN pnpm --filter @paperclipai/server build
RUN test -f server/dist/index.js || (echo "ERROR: server build output missing" && exit 1)

FROM base AS production
WORKDIR /app
COPY --chown=node:node --from=build /app /app
RUN npm install --global --omit=dev @anthropic-ai/claude-code@latest @openai/codex@latest opencode-ai \
  && mkdir -p /paperclip \
  && chown node:node /paperclip
ENV NODE_ENV=production \
  HOME=/paperclip \
  HOST=0.0.0.0 \
  PORT=3100 \
  SERVE_UI=true \
  PAPERCLIP_HOME=/paperclip \
  PAPERCLIP_INSTANCE_ID=default \
  PAPERCLIP_CONFIG=/paperclip/instances/default/config.json \
  PAPERCLIP_DEPLOYMENT_MODE=authenticated \
  PAPERCLIP_DEPLOYMENT_EXPOSURE=private
VOLUME ["/paperclip"]
EXPOSE 3100
USER node
CMD ["node", "--import", "./server/node_modules/tsx/dist/loader.mjs", "server/dist/index.js"]
