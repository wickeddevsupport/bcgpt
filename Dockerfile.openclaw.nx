# ---------- OpenClaw build stage ----------
FROM node:22-bookworm

# Install Bun (required for build scripts)
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

RUN corepack enable

WORKDIR /app

ARG OPENCLAW_DOCKER_APT_PACKAGES=""
RUN if [ -n "$OPENCLAW_DOCKER_APT_PACKAGES" ]; then \
      apt-get update && \
      DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends $OPENCLAW_DOCKER_APT_PACKAGES && \
      apt-get clean && \
      rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*; \
    fi

# Workspace metadata for Nx — must come before openclaw/ so Docker layer caches deps
COPY package.json nx.json ./

# Install root Nx deps (nx CLI only, no scripts)
RUN npm install --ignore-scripts --no-audit --no-fund --no-package-lock

# Shared PMOS bootstrap assets that must survive image rebuilds and sync into /app/.openclaw.
COPY scripts/prime-openclaw-state.mjs ./scripts/prime-openclaw-state.mjs
COPY scripts/docker/pmos-entrypoint.sh /usr/local/bin/pmos-entrypoint
COPY skills/ ./bcgpt-skills/

# Copy our custom OpenClaw fork (contains pmos UI patches, bcgpt integrations, etc.)
COPY openclaw/ ./openclaw/

# Install OpenClaw workspace deps (includes ui)
RUN corepack pnpm --dir openclaw install --frozen-lockfile

# Figma MCP support depends on mcporter being present in the runtime image.
RUN npm install -g mcporter && chmod +x /usr/local/bin/pmos-entrypoint

# Vendored n8n is legacy/opt-in and not built by default.
# Create the expected empty directory so the runtime path exists.
RUN mkdir -p /app/openclaw/vendor/n8n

# Build using Nx so both openclaw-app and openclaw-control-ui are compiled.
# openclaw-control-ui is built last to ensure dist/control-ui is present at runtime.
ENV NX_DAEMON=false
ARG OPENCLAW_NX_PROJECTS="openclaw-app,openclaw-control-ui"
RUN ./node_modules/.bin/nx run-many -t build --projects=$OPENCLAW_NX_PROJECTS --output-style=stream --skip-nx-cache \
  && ./node_modules/.bin/nx run openclaw-control-ui:build --output-style=stream --skip-nx-cache

# Force pnpm for UI build (Bun may fail on ARM/Synology architectures)
ENV OPENCLAW_PREFER_PNPM=1

ENV NODE_ENV=production
ENV MCPORTER_HOME=/app/.openclaw/mcporter
ENV MCPORTER_CONFIG_PATH=/app/.openclaw/mcporter/mcporter.json
# Make package-manager writes land in writable, non-root locations.
ENV NPM_CONFIG_PREFIX=/app/.npm-global
ENV NPM_CONFIG_CACHE=/app/.cache/npm
ENV COREPACK_HOME=/app/.cache/corepack

# Runtime UX for workspace admins:
# - provide a first-class `openclaw` CLI command in PATH
# - keep npm/corepack caches writable without root
# - allow HOME=/app workflows to create dotfiles (.npmrc, .cache, etc.)
RUN printf '#!/usr/bin/env bash\nexec node /app/openclaw/openclaw.mjs "$@"\n' > /usr/local/bin/openclaw \
  && chmod +x /usr/local/bin/openclaw \
  && mkdir -p /app/.openclaw /app/.openclaw/mcporter /app/.cache /app/.npm-global \
  && chown -R node:node /app

# Security hardening: Run as non-root user
# The node:22-bookworm image includes a 'node' user (uid 1000)
# This reduces the attack surface by preventing container escape via root privileges
USER node
WORKDIR /app/openclaw
ENTRYPOINT ["pmos-entrypoint"]

# Start gateway server with default config.
# Binds to loopback (127.0.0.1) by default for security.
#
# For container platforms requiring external health checks:
#   1. Set OPENCLAW_GATEWAY_TOKEN or OPENCLAW_GATEWAY_PASSWORD env var
#   2. Override CMD: ["node","openclaw.mjs","gateway","--allow-unconfigured","--bind","lan"]
CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
