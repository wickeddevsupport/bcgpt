{
  "id": "wicked-ops",
  "name": "Wicked Ops (Activepieces)",
  "description": "Activepieces workflow automation integration for OpenClaw",
  "version": "2.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string"
      },
      "apiKey": {
        "type": "string"
      },
      "projectId": {
        "type": "string"
      }
    }
  },
  "uiHints": {
    "baseUrl": {
      "label": "Workflow Engine URL",
      "placeholder": "https://flow.wickedlab.io"
    },
    "apiKey": {
      "label": "Workflow Engine API Key",
      "sensitive": true,
      "placeholder": "ap_..."
    },
    "projectId": {
      "label": "Workflow Engine Project ID",
      "placeholder": "proj_..."
    }
  }
}
